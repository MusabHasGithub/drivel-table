# Copy this file to .env.local and fill in real values.
#
# This is the GitHub-Pages build of drivel-table — everything runs in the
# browser, so EVERY var needs the NEXT_PUBLIC_ prefix to be inlined into
# the static bundle at build time.

# --- Firebase web SDK config ---------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Gemini ---------------------------------------------------------------
# Inlined into the static bundle. RESTRICT this key in Google Cloud Console
# (APIs & Services → Credentials → your key → Application restrictions →
# HTTP referrers → add `https://<your-username>.github.io/*` and
# `http://localhost:*` for dev). Without that restriction anyone can scrape
# the key from devtools and burn your quota.
NEXT_PUBLIC_GEMINI_API_KEY=

# --- App Check (optional) ------------------------------------------------
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
FIREBASE_APPCHECK_DEBUG_TOKEN=
