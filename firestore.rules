rules_version = '2';

// COMBINED rules for the sv-nodes Firebase project. This file holds rules
// for BOTH the sv-nodes app (under /nodes, /regions, /users) AND the
// drivel-table app (under /rooms). Deploying drivel-table/firestore.rules
// is what writes this combined ruleset to Firestore — so don't drop the
// sv-nodes blocks below or you'll break that other app.
//
// Deploy from this folder with:
//   firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------
    // sv-nodes blocks (require Firebase Auth)
    // -----------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    match /nodes/{nodeId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();

      match /{subcollection}/{docId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();
      }
    }

    match /regions/{regionId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();

      match /{subcollection}/{docId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();
      }
    }

    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // -----------------------------------------------------------------
    // drivel-table blocks (no Firebase Auth — name-only identity)
    // -----------------------------------------------------------------
    function hasSubmittedBy() {
      return 'submittedBy' in request.resource.data
        && request.resource.data.submittedBy is string
        && request.resource.data.submittedBy.size() > 0;
    }

    function hasCreatedBy() {
      return 'createdBy' in request.resource.data
        && request.resource.data.createdBy is string
        && request.resource.data.createdBy.size() > 0;
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow create: if hasCreatedBy();
      allow update, delete: if false;

      match /entries/{entryId} {
        allow read: if true;
        allow create: if hasSubmittedBy();
        // Updates (the per-cell extracted map) only happen via firebase-admin
        // which bypasses these rules. Block client writes.
        allow update, delete: if false;
      }

      match /categories/{categoryId} {
        allow read: if true;
        allow create: if hasCreatedBy();
        allow update, delete: if false;
      }
    }
  }
}
