rules_version = '2';

// COMBINED rules for the sv-nodes Firebase project. Holds rules for
// BOTH the sv-nodes app (under /nodes, /regions, /users) AND
// drivel-table (under /rooms). Deploying drivel-table/firestore.rules
// writes this combined ruleset — don't drop the sv-nodes blocks below
// or you'll break that other app.
//
// Deploy from this folder:
//   firebase deploy --only firestore:rules
//
// drivel-table runs as a static site on GitHub Pages with no server, so
// updates to entries (the per-cell extraction writes) happen from the
// browser — see lib/entries.ts and lib/categories.ts. The rules below
// allow any client with a non-empty `submittedBy` field on the entry
// to update only the `extracted` map. App Check + the slim attack
// surface (friend-group, no PII) make this acceptable for the use case.

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------
    // sv-nodes blocks (require Firebase Auth)
    // -----------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    match /nodes/{nodeId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();

      match /{subcollection}/{docId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();
      }
    }

    match /regions/{regionId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();

      match /{subcollection}/{docId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();
      }
    }

    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // -----------------------------------------------------------------
    // drivel-table blocks (no Firebase Auth — name-only identity)
    // -----------------------------------------------------------------
    function hasSubmittedBy() {
      return 'submittedBy' in request.resource.data
        && request.resource.data.submittedBy is string
        && request.resource.data.submittedBy.size() > 0;
    }

    function hasCreatedBy() {
      return 'createdBy' in request.resource.data
        && request.resource.data.createdBy is string
        && request.resource.data.createdBy.size() > 0;
    }

    // Updates that only touch the `extracted` map are permitted from the
    // browser — this is what powers per-cell extraction writes after
    // submitEntry and after addCategory's re-extraction loop. We require
    // that the existing entry already has a submittedBy (since creates
    // require it, this is always true), and that the update doesn't
    // change submittedBy / submittedAt / drivel.
    function entryUpdateOnlyExtracts() {
      return request.resource.data.submittedBy == resource.data.submittedBy
        && request.resource.data.submittedAt == resource.data.submittedAt
        && request.resource.data.drivel == resource.data.drivel;
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow create: if hasCreatedBy();
      allow update, delete: if false;

      match /entries/{entryId} {
        allow read: if true;
        allow create: if hasSubmittedBy();
        allow update: if entryUpdateOnlyExtracts();
        allow delete: if false;
      }

      match /categories/{categoryId} {
        allow read: if true;
        allow create: if hasCreatedBy();
        allow update, delete: if false;
      }
    }
  }
}
